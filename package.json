{
  "name": "quick-json-viewer",
  "displayName": "Quick JSON Viewer",
  "description": "Open big JSON files in a readonly, searchable raw-text preview without loading the full document into an editable text editor.",
  "version": "0.0.1",
  "publisher": "jsh9",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsh9/quick-json-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/jsh9/quick-json-viewer/issues"
  },
  "homepage": "https://github.com/jsh9/quick-json-viewer#readme",
  "keywords": [
    "json",
    "json-viewer",
    "large-files",
    "readonly",
    "custom-editor"
  ],
  "galleryBanner": {
    "color": "#1f6feb",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/src/extension.js",
  "activationEvents": [
    "onCustomEditor:quickJsonViewer.viewer",
    "onCommand:quickJsonViewer.openCurrentFile",
    "onCommand:quickJsonViewer.openSampleFiles"
  ],
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": false
  },
  "contributes": {
    "commands": [
      {
        "command": "quickJsonViewer.openCurrentFile",
        "title": "Open in Quick JSON Viewer",
        "category": "Quick JSON Viewer"
      }
    ],
    "languages": [
      {
        "id": "json",
        "aliases": [
          "JSON",
          "json"
        ],
        "extensions": [
          ".json"
        ]
      }
    ],
    "customEditors": [
      {
        "viewType": "quickJsonViewer.viewer",
        "displayName": "Quick JSON Viewer",
        "selector": [
          {
            "filenamePattern": "*.json"
          },
          {
            "filenamePattern": "**/*.json"
          }
        ],
        "priority": "default"
      }
    ],
    "configurationDefaults": {
      "workbench.editorAssociations": {
        "*.json": "quickJsonViewer.viewer"
      },
      "workbench.diffEditorAssociations": {
        "*.json": "default"
      }
    },
    "configuration": {
      "title": "Quick JSON Viewer",
      "properties": {
        "quickJsonViewer.largeFileThresholdMb": {
          "type": "number",
          "default": 10,
          "minimum": 0,
          "description": "Open JSON files larger than this many MiB in the readonly Quick JSON Viewer preview."
        },
        "quickJsonViewer.previewLines": {
          "type": "integer",
          "default": 100,
          "minimum": 1,
          "description": "Number of lines to show for large JSON files."
        },
        "quickJsonViewer.maxAllowablePreviewLines": {
          "type": "integer",
          "default": 10000,
          "minimum": -1,
          "description": "Maximum allowed value for quickJsonViewer.previewLines. Use -1 for no safety limit."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "quickJsonViewer.openCurrentFile",
          "when": "!isInDiffEditor"
        }
      ],
      "editor/title": [
        {
          "command": "quickJsonViewer.openCurrentFile",
          "when": "resourceScheme == file && resourceExtname == .json && !isInDiffEditor",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "quickJsonViewer.openCurrentFile",
          "when": "resourceScheme == file && resourceExtname == .json",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "npm run compile:extension && npm run typecheck:webview && npm run build:webview",
    "compile:extension": "tsc -p ./",
    "typecheck:webview": "tsc -p tsconfig.webview.json --noEmit",
    "build:webview": "node scripts/build-webview.cjs",
    "format": "prettier . --write --ignore-unknown",
    "format:check": "prettier . --check --ignore-unknown",
    "prepare": "husky",
    "test": "npm run format:check && npm run compile && npm run test:coverage",
    "test:coverage": "c8 --all --src out/src --include 'out/src/**/*.js' --check-coverage --lines 95 --branches 95 --functions 95 npm run test:unit",
    "test:unit": "node scripts/run-tests.cjs",
    "test:vscode": "npm run compile && vscode-test",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.14.8",
    "@types/vscode": "1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0",
    "c8": "^11.0.0",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "mocha": "^11.7.6",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3"
  }
}
